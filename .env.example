# Server
PORT=3000
HOST=0.0.0.0
ENV=development

# Database
DATABASE_URL=postgresql://bur:password@localhost:5432/bur?sslmode=disable

# JWT
JWT_SECRET=change-me-in-production-min-32-chars
JWT_REFRESH_SECRET=change-refresh-secret-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# Logging
LOG_LEVEL=info

# Timezone
TZ=Europe/Moscow

